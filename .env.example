# Semaphore Environment Configuration
# Copy this file to .env and customize as needed

# ===========================
# Application Settings
# ===========================
# Application name (used in logging and tracing)
SEMAPHORE_NAME=semaphore

# ===========================
# Database Configuration
# ===========================
# PostgreSQL connection settings
SEMAPHORE_DB_HOST=localhost
SEMAPHORE_DB_PORT=5432
SEMAPHORE_DB_NAME=semaphore
SEMAPHORE_DB_USER=postgres
SEMAPHORE_DB_PASSWORD=postgres

# ===========================
# Authentication & Authorization
# ===========================
# JWT validation settings
SEMAPHORE_AUTH_ISSUER=semaphore
SEMAPHORE_AUTH_AUDIENCE=semaphore-api

# HMAC secret for JWT signing/validation
# ⚠️ CRITICAL: Change this in production! Use a strong random string (32+ characters)
SEMAPHORE_AUTH_HMAC_SECRET=change-me-in-production

# Clock skew tolerance for JWT timestamps (duration format: 60s, 5m, etc.)
SEMAPHORE_AUTH_CLOCK_SKEW=60s

# ===========================
# Logging Configuration
# ===========================
# Log level: debug, info, warn, error
SEMAPHORE_LOG_LEVEL=info

# Log format: json, text
SEMAPHORE_LOG_FORMAT=json

# ===========================
# HTTP Server Configuration
# ===========================
# HTTP server listen address
SEMAPHORE_HTTP_HOST=0.0.0.0
SEMAPHORE_HTTP_PORT=8080

# ===========================
# gRPC Server Configuration
# ===========================
# gRPC server listen address
SEMAPHORE_TRANSPORT_GRPC_HOST=0.0.0.0
SEMAPHORE_TRANSPORT_GRPC_PORT=9090

# ===========================
# Health Check Configuration
# ===========================
# Health check endpoint path
SEMAPHORE_HEALTH_PATH=/health

# ===========================
# Tracing Configuration (Optional)
# ===========================
# Enable distributed tracing
SEMAPHORE_TRACING_ENABLED=false

# OpenTelemetry exporter endpoint (if tracing enabled)
# SEMAPHORE_TRACING_OTLP_ENDPOINT=http://localhost:4318

# ===========================
# Test Client Configuration
# ===========================
# Settings for the included test client (./testclient/main.go)
# These should match your SEMAPHORE_AUTH_* values above
TESTCLIENT_AUTH_ISSUER=semaphore
TESTCLIENT_AUTH_AUDIENCE=semaphore-api
TESTCLIENT_AUTH_HMAC_SECRET=change-me-in-production
TESTCLIENT_AUTH_SUBJECT=testclient
