# Semaphore Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL database name
SEMAPHORE_DB_NAME=semaphore

# PostgreSQL user
SEMAPHORE_DB_USER=postgres

# PostgreSQL password (CHANGE THIS IN PRODUCTION)
SEMAPHORE_DB_PASSWORD=postgres

# PostgreSQL host (use 'postgres' for docker-compose, 'localhost' for local dev)
SEMAPHORE_DB_HOST=postgres

# PostgreSQL port
SEMAPHORE_DB_PORT=5432

# SSL mode for database connection (disable, require, verify-ca, verify-full)
SEMAPHORE_DB_SSLMODE=disable

# =============================================================================
# Authentication & Authorization
# =============================================================================
# JWT issuer identifier
SEMAPHORE_AUTH_ISSUER=semaphore

# JWT audience (who the token is intended for)
SEMAPHORE_AUTH_AUDIENCE=semaphore-api

# HMAC secret for JWT signing (CHANGE THIS IN PRODUCTION - use a strong random value)
SEMAPHORE_AUTH_HMAC_SECRET=change-me-in-production

# Clock skew tolerance for JWT validation (e.g., 10s, 1m)
SEMAPHORE_AUTH_CLOCK_SKEW=10s

# =============================================================================
# HTTP Server
# =============================================================================
# HTTP server port
SEMAPHORE_HTTP_PORT=8080

# HTTP server bind address (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
SEMAPHORE_HTTP_HOST=0.0.0.0

# =============================================================================
# gRPC Server
# =============================================================================
# gRPC server port
SEMAPHORE_GRPC_PORT=9090

# gRPC server bind address
SEMAPHORE_GRPC_HOST=0.0.0.0

# =============================================================================
# Logging
# =============================================================================
# Log level (debug, info, warn, error, fatal, panic)
SEMAPHORE_LOG_LEVEL=info

# Log format (json, text)
SEMAPHORE_LOG_FORMAT=json

# =============================================================================
# Tracing (OpenTelemetry)
# =============================================================================
# Enable distributed tracing
SEMAPHORE_TRACE_ENABLED=false

# Trace exporter type (stdout, otlp, jaeger)
SEMAPHORE_TRACE_EXPORTER=stdout

# OTLP endpoint (if using otlp exporter)
# SEMAPHORE_TRACE_OTLP_ENDPOINT=http://localhost:4318

# =============================================================================
# Health Checks
# =============================================================================
# Health check endpoint port
SEMAPHORE_HEALTH_PORT=8081

# =============================================================================
# Test Client Configuration (for local testing only)
# =============================================================================
# These match the auth settings above for the included test client
TESTCLIENT_AUTH_ISSUER=semaphore
TESTCLIENT_AUTH_AUDIENCE=semaphore-api
TESTCLIENT_AUTH_HMAC_SECRET=change-me-in-production
TESTCLIENT_AUTH_SUBJECT=testclient
